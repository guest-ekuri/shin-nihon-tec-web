---
import { client, type Event } from '../library/microcms';

// microCMSからイベント一覧を取得
const response = await client.getList<Event>({ endpoint: "events" });
const events = response.contents;
---

<section id="special" class="py-20 bg-surface-alt">
    <div class="container mx-auto px-4 max-w-5xl">
        <div class="text-center mb-12 md:mb-16">
            <span class="text-accent font-eng tracking-widest text-sm md:text-base font-bold block mb-2 uppercase">Special</span>
            <h2 class="text-3xl md:text-4xl font-bold text-primary mb-4">特設ページ・イベント</h2>
            <div class="w-12 h-1 bg-accent mx-auto"></div>
        </div>
        <div class="grid md:grid-cols-2 gap-12">
            
            <div class="bg-surface p-8 rounded-xl shadow-md border-t-4 border-primary">
                <h3 class="text-2xl font-bold text-primary mb-6 flex items-center">
                    <i class="fas fa-shield-alt text-primary mr-3"></i>感染症対策
                </h3>
                <div class="bg-light p-6 rounded-lg border border-border">
                    <p class="mb-4 text-sm font-bold text-primary">社内および現場における安全対策を徹底しています。</p>
                    <ul class="space-y-4 mb-6">
                        <li class="flex items-start">
                            <span class="bg-surface-alt text-primary p-1 rounded mr-3 text-xs border border-border">対策</span>
                            <div>
                                <span class="block font-bold text-primary text-sm">指先消毒・除菌</span>
                                <span class="text-xs text-text-muted">玄関や居室入口にアルコール消毒液を設置</span>
                            </div>
                        </li>
                        <li class="flex items-start">
                            <span class="bg-surface-alt text-primary p-1 rounded mr-3 text-xs border border-border">対策</span>
                            <div>
                                <span class="block font-bold text-primary text-sm">空間除菌</span>
                                <span class="text-xs text-text-muted">各居室に「次亜塩素酸 空間除菌脱臭機」を設置</span>
                            </div>
                        </li>
                        <li class="flex items-start">
                            <span class="bg-surface-alt text-primary p-1 rounded mr-3 text-xs border border-border">対策</span>
                            <div>
                                <span class="block font-bold text-primary text-sm">飛沫対策</span>
                                <span class="text-xs text-text-muted">個人デスク間を抗菌フィルムで隔離</span>
                            </div>
                        </li>
                    </ul>
                    <div class="text-center">
                        <a href="/special" class="inline-block bg-primary text-white text-sm font-bold py-2 px-6 rounded-full hover:opacity-80 transition shadow">
                            詳細を見る
                        </a>
                    </div>
                </div>
            </div>

            <div class="bg-surface p-8 rounded-xl shadow-md border-t-4 border-accent">
                <h3 class="text-2xl font-bold text-primary mb-6 flex items-center">
                    <i class="fas fa-glass-cheers text-accent mr-3"></i>イベント
                </h3>
                <p class="mb-4 text-sm text-text-body">社内行事や記念イベントの様子を公開しています。</p>
                
                <div class="space-y-2">
                    {events.map((event) => (
                        /* microCMSのデータIDを使って /events/【ID】 へのリンクを作成 */
                        <a href={`/events/${event.id}`} class="block p-3 border-b border-border hover:bg-accent-muted transition rounded-lg group">
                            <div class="text-xs text-text-muted mb-1">
                                {new Date(event.date).toLocaleDateString("ja-JP")}
                                <span class="bg-accent text-white px-2 py-0.5 rounded text-xs ml-2">
                                    {event.tags}
                                </span>
                            </div>
                            <div class="text-primary font-bold group-hover:text-accent transition">
                                {event.event_title}
                            </div>
                        </a>
                    ))}
                </div>
            </div>
        </div>
    </div>
</section>