---
import { client, type Event } from '../library/microcms';

// microCMSからイベントデータを取得
const response = await client.getList<Event>({ endpoint: "events" });
const events = response.contents;

// タグのカラー辞書（テーマカラーに合わせてカスタマイズ）
const tagColors: Record<string, string> = {
  "お知らせ": "bg-accent-muted text-accent font-bold",   // 【薄い赤背景 × 赤文字】今風でスタイリッシュな表現
  "Web更新": "bg-accent-muted text-accent font-bold",   // 【薄い赤背景 × 赤文字】今風でスタイリッシュな表現
  "実績紹介": "bg-primary text-white",                   // 【黒】シックで公式感を出したい時
  "記念式典": "bg-accent text-white",                    // 【コーポレートレッド】メインのアクティビティ
  "社内行事": "bg-accent text-white",                    // 【コーポレートレッド】メインのアクティビティ
  "アーカイブ": "bg-text-muted text-white",                  // 【薄いグレー】目立たせたくない時
  "その他": "bg-text-muted text-white",                  // 【薄いグレー】目立たせたくない時
};

// 【追加】カメラの準備状況を管理するフラグ
// 設置が完了したらここを true に変えるだけで、自動的に表示とリンクが有効になります。
// const isCameraReady = false; 
const isCameraReady = true; 
---


<section id="special" class="py-20 bg-surface-alt">
    <div class="w-full px-4 md:px-10 lg:px-16">
        <div class="text-center mb-12 md:mb-16">
            <span class="text-accent font-eng tracking-widest text-sm md:text-base font-bold block mb-2 uppercase">Special</span>
            <h2 class="text-3xl md:text-4xl font-bold text-primary mb-4">特設ページ・イベント</h2>
            <div class="w-12 h-1 bg-accent mx-auto"></div>
        </div>

        <!-- 特設、イベント一覧 -->
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6 lg:gap-10">
            
            <!-- リニア駅建設 -->            
            <div class="bg-surface p-8 rounded-xl shadow-md border-t-4 border-accent flex flex-col justify-between group h-full">
                <div>
                    <h3 class="text-2xl font-bold text-primary mb-6 flex items-center">
                        <i class="fas fa-train text-accent mr-3"></i>リニア駅建設
                    </h3>
                    
                    <div class="relative rounded-lg overflow-hidden mb-6 aspect-video bg-gray-200 flex items-center justify-center">
                        {isCameraReady ? (
                            /* 準備完了時：画像とLIVEバッジを表示 */
                            <>
                                <div class="absolute top-3 left-3 z-10">
                                    <span class="bg-red-600 text-white text-[10px] font-bold px-2 py-0.5 rounded animate-pulse">LIVE MONITOR</span>
                                </div>
                                <img 
                                    src="/assets/images/image1.jpg" 
                                    alt="リニア建設現場" 
                                    class="w-full h-full object-cover transition duration-500 group-hover:scale-110" 
                                />
                            </>
                        ) : (
                            /* 準備中：グレーの背景とCOMING SOONテキストのみ */
                            <div class="flex flex-col items-center justify-center p-4">
                                <i class="fas fa-video-slash text-5xl text-gray-400 mb-4"></i>
                                <span class="text-gray-500 font-bold tracking-widest border-2 border-gray-300 px-4 py-2 text-sm">COMING SOON</span>
                                <p class="text-gray-400 text-xs mt-3">定点カメラ 設置準備中</p>
                            </div>
                        )}
                    </div>
                    
                    <p class="text-sm text-text-body leading-relaxed mb-6">
                        甲府市大津町に建設中の「リニア中央新幹線 山梨県駅」。地元企業として、その進捗を独自に記録・公開する予定です。
                    </p>
                </div>

                <div class="text-center mt-auto pt-8">
                    {isCameraReady ? (
                        <a href="/special" class="inline-block bg-accent hover:bg-accent-hover text-white text-sm font-bold py-3 px-10 rounded-full transition shadow-lg transform hover:-translate-y-0.5">
                            ライブ映像・詳細を見る
                        </a>
                    ) : (
                        <button disabled class="inline-block bg-gray-300 text-gray-500 text-sm font-bold py-3 px-10 rounded-full cursor-not-allowed shadow-inner">
                            近日公開
                        </button>
                    )}
                </div>
            </div>
        
            <!-- 感染症対策 -->
            <div class="bg-surface p-8 rounded-xl shadow-md border-t-4 border-primary flex flex-col justify-between h-full">
                <h3 class="text-2xl font-bold text-primary mb-6 flex items-center">
                    <i class="fas fa-shield-alt text-primary mr-3"></i>感染症対策
                </h3>
                <div class="bg-light p-6 rounded-lg border border-border">
                    <p class="mb-4 text-sm font-bold text-primary">社内および現場における安全対策を徹底しています。</p>
                    <ul class="space-y-4 mb-6">
                        <li class="flex items-start">
                            <span class="bg-surface-alt text-primary p-1 rounded mr-3 text-xs border border-border">対策</span>
                            <div>
                                <span class="block font-bold text-primary text-sm">指先消毒・除菌</span>
                                <span class="text-xs text-text-muted">玄関や居室入口にアルコール消毒液を設置</span>
                            </div>
                        </li>
                        <li class="flex items-start">
                            <span class="bg-surface-alt text-primary p-1 rounded mr-3 text-xs border border-border">対策</span>
                            <div>
                                <span class="block font-bold text-primary text-sm">空間除菌</span>
                                <span class="text-xs text-text-muted">各居室に「次亜塩素酸 空間除菌脱臭機」を設置</span>
                            </div>
                        </li>
                        <li class="flex items-start">
                            <span class="bg-surface-alt text-primary p-1 rounded mr-3 text-xs border border-border">対策</span>
                            <div>
                                <span class="block font-bold text-primary text-sm">飛沫対策</span>
                                <span class="text-xs text-text-muted">個人デスク間を抗菌フィルムで隔離</span>
                            </div>
                        </li>
                    </ul>
                </div>

                <div class="text-center mt-auto pt-8">
                    <a href="/special" class="inline-block bg-primary text-white text-sm font-bold py-3 px-10 rounded-full hover:opacity-80 transition shadow-lg transform hover:-translate-y-0.5">
                        詳細を見る
                    </a>
                </div>
            </div>

            <!-- イベント＆お知らせ -->
            <div class="bg-surface p-8 pb-10 rounded-xl shadow-md border-t-4 border-accent flex flex-col justify-between h-full">
                <div>
                    <h3 class="text-2xl font-bold text-primary mb-6 flex items-center">
                        <i class="fas fa-glass-cheers text-accent mr-3"></i>イベント＆お知らせ
                    </h3>
                    <p class="mb-4 text-sm text-text-body">社内行事や記念イベントの様子を公開しています。</p>
                
                    <div class="space-y-2 max-h-[320px] overflow-y-auto pr-2 custom-scrollbar">
                        {events.map((event) => {
                            // ▼ ページ遷移を許可するタグのリスト ▼
                            const linkableTags = ["記念式典", "社内行事", "アーカイブ"];
                            
                            // tagsの中に、上記の許可リストのタグが1つでも含まれているかチェック
                            const hasLink = event.tags && event.tags.some(tag => linkableTags.includes(tag));

                            return hasLink ? (
                                /* ▼ 遷移するタグの場合（詳細ページへ） ▼ */
                                <a href={`/events/${event.id}`} class="block p-3 border-b border-border hover:bg-accent-muted transition rounded-lg group">
                                    <div class="text-xs text-text-muted mb-1 flex items-center flex-wrap gap-1">
                                        {new Date(event.date).toLocaleDateString("ja-JP")}
                                        {event.tags && event.tags.map((tag) => (
                                            <span class={`px-2 py-0.5 rounded text-xs ${tagColors[tag] || tagColors["デフォルト"]}`}>
                                                {tag}
                                            </span>
                                        ))}
                                    </div>
                                    <div class="text-primary font-bold group-hover:text-accent transition">
                                        {event.content}
                                    </div>
                                </a>
                            ) : (
                                /* ▼ 遷移しないタグの場合（お知らせ、Web更新など） ▼ */
                                <div class="block p-3 border-b border-border rounded-lg bg-surface">
                                    <div class="text-xs text-text-muted mb-1 flex items-center flex-wrap gap-1">
                                        {new Date(event.date).toLocaleDateString("ja-JP")}
                                        {event.tags && event.tags.map((tag) => (
                                            <span class={`px-2 py-0.5 rounded text-xs ${tagColors[tag] || tagColors["デフォルト"]}`}>
                                                {tag}
                                            </span>
                                        ))}
                                    </div>
                                    <div class="text-primary font-bold">
                                        {event.content}
                                    </div>
                                </div>
                            );
                        })}
                    </div>
                </div>

                <div class="text-center mt-auto pt-8">
                    <a href="/events" class="inline-block bg-accent hover:bg-accent-hover text-white text-sm font-bold py-3 px-10 rounded-full transition shadow-lg transform hover:-translate-y-0.5">
                        一覧を見る
                    </a>
                </div>
            </div>

        </div>
    </div>
</section>