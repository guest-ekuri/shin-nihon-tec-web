---
import { client, type Event } from '../library/microcms';

// microCMSからデータを取得
const response = await client.getList<Event>({ endpoint: "events" });

// 「お知らせ」または「Web更新」のタグを持つ記事を最新2件だけ抽出
const infoItems = response.contents
  .filter(item => 
    item.tags && (item.tags.includes("お知らせ") || item.tags.includes("Web更新"))
  )
  .slice(0, 2); // ヒーローセクションのサイズに合わせて2件に絞る

  // ▼ ここに追加：タグの英語表記辞書 ▼
const tagLabels: Record<string, string> = {
  "お知らせ": "Info",
  "Web更新": "News",
  // 必要であれば他のタグも追加できます
  // "実績紹介": "Works",
  // "記念式典": "Event",
};
---

<section class="hero-bg bg-cover bg-no-repeat bg-right h-screen min-h-[600px] flex items-center justify-center text-white mt-16 relative">
    <!-- 左テキストエリアに半透明白背景を追加 -->  
    <div class="absolute inset-0 bg-gradient-to-tr from-secondary/100 to-transparent to-[60%] pointer-events-none"></div>
    <!-- 画面左テキスト -->
    <div class="relative z-10 container mx-auto px-4 grid md:grid-cols-2 gap-8 items-center pt-16">
        <div class="text-left">
            <span class="inline-block py-1 px-3 border border-white/50 rounded-full text-sm mb-4 tracking-wider bg-white/10 backdrop-blur">
                電気工事・自動制御システム・CO2削減のプロ集団
            </span>
            <h1 class="text-3xl md:text-5xl lg:text-6xl font-bold mb-6 leading-tight drop-shadow-lg">
                技術と誠意で80年、<br>
                そして<span class="text-accent-top">100年</span>へ。
            </h1>
            <p class="text-lg md:text-xl mb-8 text-gray-200 leading-relaxed max-w-lg drop-shadow-md">
                他社に負けない低価格、敏速な対応。<br>
                お客様の立場に立った提案をいたします。
            </p>
            <div class="flex flex-col sm:flex-row gap-4">
                <a href="#contact" class="bg-accent hover:bg-accent-hover text-white text-center font-bold py-4 px-8 rounded shadow-lg transition transform hover:-translate-y-1">
                    ご相談・お見積もり
                </a>
                <a href="#service" class="bg-white/10 hover:bg-white/20 backdrop-blur border border-white text-white text-center font-bold py-4 px-8 rounded shadow transition">
                    事業内容を見る
                </a>
            </div>
        </div>

        <!-- Information ボックス -->
        <div class="hidden md:block relative">
            <div class="bg-black/30 backdrop-blur-md p-6 rounded-lg border border-white/20 max-w-sm ml-auto shadow-2xl">
                <h3 class="font-bold text-lg mb-2 border-b border-white/30 pb-2">Information</h3>
                
                {infoItems.length > 0 ? infoItems.map((item) => (
                    <div class="mb-3 last:mb-0 pt-2">
                        <p class="text-sm">
                            {/* 日付を YYYY.MM.DD 形式に変換 */}
                            <span class="text-gray-300 mr-2">{new Date(item.date).toLocaleDateString("ja-JP").replace(/\//g, '.')}</span>
                            {/* タグを表示 */}
                            {item.tags && item.tags.map(tag => (
                                <span class="bg-secondary text-xs px-2 py-0.5 rounded ml-1 font-semibold">
                                    {tagLabels[tag] || tag}
                                </span>
                            ))}
                            <br />
                            {/* 内容を表示 */}
                            <span class="inline-block mt-1">{item.content}</span>
                        </p>
                    </div>
                )) : (
                    <p class="text-sm text-white/70 pt-2">現在、新しいお知らせはありません。</p>
                )}
            </div>
        </div>
    </div>
    
    <!-- スクロールダウンアイコン -->
    <div class="absolute bottom-8 left-1/2 transform -translate-x-1/2 animate-bounce">
        <a href="#about" class="text-white opacity-80 hover:opacity-100">
            <svg class="w-8 h-8" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 14l-7 7m0 0l-7-7m7 7V3"></path></svg>
        </a>
    </div>
</section>