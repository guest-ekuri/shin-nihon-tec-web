---
// ここはAstroのプログラムを書く場所です（今回はCSSを読み込みます）
import '../styles/common.css';
import '../styles/top.css';
---

<!DOCTYPE html>
<html lang="ja">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>株式会社 新ニホンテック | 技術と誠意で80年、そして100年へ</title>
    
    <link href="https://fonts.googleapis.com/css2?family=Noto+Sans+JP:wght@300;400;500;700&family=Oswald:wght@300;400;500;700&display=swap" rel="stylesheet">
    <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css" rel="stylesheet">
</head>
<body class="text-gray-800 scroll-smooth bg-gray-50 flex flex-col min-h-screen">

    <header class="bg-white/95 backdrop-blur shadow-md fixed w-full z-50 transition-all duration-300">
        <div class="container mx-auto px-4 py-3 flex justify-between items-center">
            <a href="/" class="text-xl md:text-2xl font-bold text-primary flex items-center group leading-none">
                <img src="/assets/images/logo.png" alt="新ニホンテック" class="h-10 md:h-12 w-auto mr-3 group-hover:opacity-80 transition">
                <div>
                    <span class="block text-xs md:text-sm text-gray-500 font-normal">電気工事・自動制御・CO2削減</span>
                    株式会社 新ニホンテック
                </div>
            </a>
            
            <nav class="hidden xl:flex space-x-6 text-sm font-bold text-gray-700 items-center">
                <a href="/#about" class="hover:text-secondary transition py-2 border-b-2 border-transparent hover:border-secondary">企業情報</a>
                <a href="/#service" class="hover:text-secondary transition py-2 border-b-2 border-transparent hover:border-secondary">事業内容</a>
                <a href="/#special" class="hover:text-secondary transition py-2 border-b-2 border-transparent hover:border-secondary">特設・イベント</a>
                <a href="/#recruit" class="hover:text-secondary transition py-2 border-b-2 border-transparent hover:border-secondary">採用情報</a>
                <a href="/#access" class="hover:text-secondary transition py-2 border-b-2 border-transparent hover:border-secondary">アクセス</a>
                <a href="#contact" class="bg-secondary hover:bg-emerald-600 text-white px-6 py-2 rounded-full transition shadow-lg transform hover:-translate-y-0.5">
                    お問い合わせ
                </a>
            </nav>
        </div>
    </header>

    <slot />

    <footer class="bg-gray-900 text-gray-400 py-12 border-t border-gray-800">
        <div class="container mx-auto px-4 text-center md:text-left">
            <div class="grid md:grid-cols-3 gap-8 mb-12">
                <div>
                    <h3 class="text-2xl font-bold text-white mb-4">株式会社 新ニホンテック</h3>
                    <p class="text-sm leading-relaxed">
                        〒400-0057 山梨県甲府市高室町688-2<br>
                        TEL: 055-241-9231 / FAX: 055-241-9223
                    </p>
                </div>
                <div>
                    <h4 class="text-white font-bold mb-4">メニュー</h4>
                    <div class="flex flex-col md:flex-row gap-8 text-sm">
                        <ul class="space-y-2">
                            <li><a href="#about" class="hover:text-white transition">企業情報</a></li>
                            <li><a href="#service" class="hover:text-white transition">事業内容</a></li>
                            <li><a href="#special" class="hover:text-white transition">特設・イベント</a></li>
                        </ul>
                        <ul class="space-y-2">
                            <li><a href="#recruit" class="hover:text-white transition">採用情報</a></li>
                            <li><a href="#access" class="hover:text-white transition">アクセス</a></li>
                            <li><a href="#contact" class="hover:text-white transition">お問い合わせ</a></li>
                        </ul>
                    </div>
                </div>
                <div class="text-center md:text-right">
                    <a href="#" class="inline-block bg-gray-800 hover:bg-gray-700 text-white px-4 py-2 rounded transition">
                        <i class="fas fa-arrow-up mr-2"></i> ページトップへ
                    </a>
                </div>
            </div>
            
            <div class="pt-8 border-t border-gray-800 text-center text-sm">
                <p>© SHINNIHONTEC CO., LTD. All Rights Reserved.</p>
            </div>
        </div>
    </footer>

</body>
</html>