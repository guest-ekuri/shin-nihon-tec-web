    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>株式会社 新ニホンテック | 技術と誠意で80年、そして100年へ</title>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/swiper@11/swiper-bundle.min.css" />
    <link href="https://fonts.googleapis.com/css2?family=Noto+Sans+JP:wght@300;400;500;700&family=Oswald:wght@300;400;500;700&display=swap" rel="stylesheet">
    <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css" rel="stylesheet">
    <link rel="icon" type="image/png" href="/assets/images/logo.png" />
</head>
<body class="text-gray-800 scroll-smooth bg-gray-50 flex flex-col min-h-screen">

    <header class="bg-surface/95 backdrop-blur shadow-md fixed w-full z-50 transition-all duration-300">
