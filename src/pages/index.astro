---
import Layout from '../layouts/Layout.astro';

import Opening from '../components/Opening.astro';
import Hero from '../components/Hero.astro';
import Live from '../components/Live.astro';

import About from '../components/About.astro';
import Company from '../components/Company.astro';
import Strength from '../components/Strength.astro';
import Service from '../components/Service.astro';
import Works from '../components/Works.astro';
import Workflow from '../components/Workflow.astro';
import Special from '../components/Special.astro';
import Recruit from '../components/Recruit.astro';
import Access from '../components/Access.astro';
import Contact from '../components/Contact.astro';
---

<Layout>
    <section class="h-screen min-h-[600px] mt-16 relative">
        <div class="swiper myHeroSwiper w-full h-full">
            <div class="swiper-wrapper">
                
                <div class="swiper-slide relative bg-gray-900 flex items-center">
                    <!-- <div class="absolute inset-0 bg-[url('/assets/images/image1.jpg')] bg-cover bg-center grayscale opacity-50"></div> -->
                     <Opening />
                </div>

                <div class="swiper-slide relative bg-gray-900 flex items-center">
                     <Hero />
                </div>

                <div class="swiper-slide relative bg-surface-alt flex flex-col items-center justify-center">
                    <Live />
                </div>
            </div>
            
            <div class="swiper-pagination"></div>
            <div class="swiper-button-next !text-white drop-shadow"></div>
            <div class="swiper-button-prev !text-white drop-shadow"></div>
        </div>
    </section>

    <script src="https://cdn.jsdelivr.net/npm/swiper@11/swiper-bundle.min.js" is:inline></script>
    <script is:inline>
      document.addEventListener('DOMContentLoaded', function () {
        const swiper = new Swiper('.myHeroSwiper', {
          loop: true, // 最後までいったら最初に戻るループ設定
          
          // 自動再生と手動操作を両立する設定
          autoplay: {
            delay: 5000, // 5000ミリ秒（5秒）ごとにスライド
            disableOnInteraction: false, // ユーザーが矢印やドットを操作しても自動再生を止めない
            pauseOnMouseEnter: true, // ★マウスがスライドに乗っている間は一時停止する
          },
          
          // エフェクト（お好みで 'fade' に変更してもかっこいいです）
          effect: 'slide', 
          
          // ドット（ページネーション）の設定
          pagination: {
            el: '.swiper-pagination',
            clickable: true, // ドットをクリックして直接そのスライドに飛べるようにする
          },
          
          // 左右の矢印（ナビゲーション）の設定
          navigation: {
            nextEl: '.swiper-button-next',
            prevEl: '.swiper-button-prev',
          },
        });
      });
    </script>


    <About />
    <Company />
    <Strength />
    <Service />
    <Works />
    <Workflow />
    <Special />
    <Recruit />
    <Access />
    <Contact />
    
    <script src="/assets/js/common.js" is:inline></script>
    <script src="/assets/js/top.js" is:inline></script>

</Layout>