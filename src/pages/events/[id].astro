---
import { client, type Event } from "../../library/microcms";
import Layout from "../../layouts/Layout.astro"; // Layoutのパスは環境に合わせて調整してください

// 動的ルートの設定
export async function getStaticPaths() {
  const response = await client.getList<Event>({ endpoint: "events" });
  return response.contents.map((content) => ({
    params: { id: content.id },
    props: { event: content },
  }));
}

const { event } = Astro.props;
---

<Layout>
  <section class="bg-primary text-white py-24 relative overflow-hidden mt-16">
    <div class="absolute inset-0 opacity-10 bg-[url('https://www.transparenttextures.com/patterns/cubes.png')]"></div>
    <div class="container mx-auto px-4 relative z-10 text-center">
      <span class="inline-block bg-accent text-white text-xs font-bold px-3 py-1 rounded-full mb-4 tracking-wider uppercase">Event Report</span>
      <h1 class="text-3xl md:text-5xl font-bold mb-4">{event.event_title}</h1>
      <p class="text-blue-200 font-eng tracking-widest uppercase">{event.english_title}</p>
    </div>
  </section>

  <main class="container mx-auto px-4 max-w-5xl py-12">
    <div class="mb-16">
      <h2 class="text-2xl font-bold text-center text-primary mb-8">
        <span class="border-b-4 border-accent pb-1">PHOTO GALLERY</span>
      </h2>
      <p class="text-center text-gray-500 text-sm mb-6">当日の様子をご紹介します</p>

      <div class="relative bg-black rounded-xl overflow-hidden shadow-2xl group h-[300px] md:h-[500px]" id="gallery-container">
        
        {event.photo_gallery.map((item, index) => (
          /* microCMSのデータでスライドを動的に生成（Tailwind CDNで動くようにクラス名を調整） */
          <div class={`slide w-full h-full absolute transition-opacity duration-500 ${index === 0 ? 'opacity-100 z-10' : 'opacity-0 z-0'}`} data-index={index}>
            <img src={item.image.url} class="w-full h-full object-cover opacity-80" alt={item.photo_title}>
            <div class="absolute bottom-0 left-0 w-full bg-gradient-to-t from-black/80 to-transparent p-6 text-white">
              <h3 class="text-xl font-bold">{item.photo_title}</h3>
            </div>
          </div>
        ))}

        <button id="prev-btn" class="absolute left-4 top-1/2 transform -translate-y-1/2 bg-white/20 hover:bg-white/40 text-white rounded-full p-3 transition backdrop-blur-sm z-20">
          <i class="fas fa-chevron-left text-xl"></i>
        </button>
        <button id="next-btn" class="absolute right-4 top-1/2 transform -translate-y-1/2 bg-white/20 hover:bg-white/40 text-white rounded-full p-3 transition backdrop-blur-sm z-20">
          <i class="fas fa-chevron-right text-xl"></i>
        </button>

        <div class="absolute bottom-4 right-4 flex space-x-2 z-20">
          {event.photo_gallery.map((_, index) => (
            <span class={`dot w-3 h-3 bg-white rounded-full transition ${index === 0 ? 'opacity-100' : 'opacity-50'}`} data-index={index}></span>
          ))}
        </div>
      </div>
    </div>

    <div class="text-center mb-8">
      <a href="/#special" class="inline-block bg-gray-200 hover:bg-gray-300 text-gray-600 font-bold py-3 px-8 rounded-full transition">
        イベント一覧に戻る
      </a>
    </div>
  </main>
</Layout>

<script>
  const setupSlider = () => {
    const slides = document.querySelectorAll('.slide');
    const dots = document.querySelectorAll('.dot');
    
    // スライドが1枚以下の場合は矢印を隠して処理を終了（元のスクリプトの条件を反映）
    if (slides.length <= 1) {
      document.getElementById('prev-btn')?.classList.add('hidden');
      document.getElementById('next-btn')?.classList.add('hidden');
      return;
    }

    let currentIndex = 0;
    let slideTimer; // タイマーを管理する変数

    // スライドとドットの表示を更新する関数
    const updateDisplay = () => {
      slides.forEach((slide, index) => {
        if (index === currentIndex) {
          slide.classList.remove('opacity-0', 'z-0');
          slide.classList.add('opacity-100', 'z-10');
        } else {
          slide.classList.remove('opacity-100', 'z-10');
          slide.classList.add('opacity-0', 'z-0');
        }
      });

      dots.forEach((dot, index) => {
        if (index === currentIndex) {
          dot.classList.remove('opacity-50');
          dot.classList.add('opacity-100');
        } else {
          dot.classList.remove('opacity-100');
          dot.classList.add('opacity-50');
        }
      });
    };

    // 次のスライドへ進む関数（自動再生でも手動でも使います）
    const nextSlide = () => {
      currentIndex = (currentIndex + 1) % slides.length;
      updateDisplay();
    };

    // 自動再生のタイマーをスタートする関数
    const startTimer = () => {
      slideTimer = setInterval(nextSlide, 5000); // 5秒（5000ミリ秒）ごとに実行
    };

    // 手動操作時にタイマーをリセットする関数
    const resetTimer = () => {
      clearInterval(slideTimer); // 今動いているタイマーを一旦止める
      startTimer(); // ゼロからまた5秒カウントを再開する
    };

    // 前へボタン
    document.getElementById('prev-btn')?.addEventListener('click', () => {
      currentIndex = (currentIndex - 1 + slides.length) % slides.length;
      updateDisplay();
      resetTimer(); // 自分で操作した後はタイマーリセット
    });

    // 次へボタン
    document.getElementById('next-btn')?.addEventListener('click', () => {
      nextSlide();
      resetTimer(); // 自分で操作した後はタイマーリセット
    });

    // 最初にページが開かれた時に、自動再生をスタート！
    startTimer();
  };

  // スクリプトを実行
  setupSlider();
</script>